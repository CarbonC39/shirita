{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shirita",
  "version": "0.0.0",
  "identifier": "app.shirita.desktop",
  "build": {
    "frontendDist": "../shirita-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../shirita-ui run dev"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; img-src 'self' http://127.0.0.1:* data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "category": "Utility",
    "shortDescription": "Shirita desktop",
    "longDescription": "Shirita — a local AI chat desktop app.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
